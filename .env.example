JWT_SECRET=change-me-in-production-use-32-chars-min
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

POSTGRES_AUTH_URL=postgresql+asyncpg://postgres:postgres@postgres-auth:5432/auth_db
POSTGRES_MAIN_URL=postgresql+asyncpg://postgres:postgres@postgres-main:5432/main_db
POSTGRES_GEO_URL=postgresql+asyncpg://postgres:postgres@postgres-geo:5432/geo_db
